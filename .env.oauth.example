# ==========================================
# CinemaX - Environment Configuration
# ==========================================

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=cinema_db
DB_USERNAME=root
DB_PASSWORD=

# ==========================================
# GOOGLE OAUTH 2.0 CONFIGURATION
# ==========================================
# Get credentials from: https://console.cloud.google.com/
# 1. Create a project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 Client ID
# 4. Add authorized redirect URI

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# For production, use:
# GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback

# ==========================================
# ZALO OAUTH CONFIGURATION
# ==========================================
# Get credentials from: https://developers.zalo.me/
# 1. Create an application
# 2. Get App ID and Secret Key
# 3. Add callback URL in settings

ZALO_APP_ID=your-zalo-app-id
ZALO_APP_SECRET=your-zalo-app-secret
ZALO_REDIRECT_URI=http://localhost:8000/auth/zalo/callback

# For production, use:
# ZALO_REDIRECT_URI=https://yourdomain.com/auth/zalo/callback

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# ==========================================
# SESSION CONFIGURATION
# ==========================================
SESSION_LIFETIME=7200
SESSION_SECURE=false
SESSION_HTTPONLY=true

# ==========================================
# NOTES
# ==========================================
# - Copy this file to .env and fill in your actual credentials
# - Never commit .env file to version control
# - For production, set APP_DEBUG=false and SESSION_SECURE=true
# - Zalo does not provide user email, system creates placeholder email
# - Google provides email, name, and profile picture
